# Which LLM provider to use: openai | groq | anthropic | none
# "none" runs in offline fallback mode (no API key needed) — good for a
# first test run before you wire up a real provider.
LLM_PROVIDER=none

# --- OpenAI ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# --- Groq (OpenAI-compatible, free tier available) ---
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant

# --- Anthropic ---
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# Server port
PORT=5000
